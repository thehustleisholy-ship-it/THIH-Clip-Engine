# THIH Clip Engine Environment Configuration
# Copy this file and fill in your API keys

# ==============================================
# AI Provider API Keys (Required for video processing)
# ==============================================

# AssemblyAI - Required for video transcription with word-level timing
ASSEMBLY_AI_API_KEY=
# Upload/transcription HTTP timeout in seconds. Larger videos need more time to upload.
ASSEMBLY_AI_HTTP_TIMEOUT_SECONDS=900
# Optional. Current AssemblyAI speech models used for transcription fallback order.
ASSEMBLYAI_SPEECH_MODELS=universal-3-pro,universal-2

# Choose one AI provider for transcript analysis:
# OpenAI (recommended: gpt-5.2)
OPENAI_API_KEY=

# Google AI (recommended: gemini-3-flash)
GOOGLE_API_KEY=

# Anthropic (claude-3-5-sonnet, claude-4-sonnet)
ANTHROPIC_API_KEY=

# Ollama (local/self-hosted or Ollama Cloud)
# Optional. Defaults to http://localhost:11434/v1 for local backend runs,
# or http://host.docker.internal:11434/v1 inside Docker.
OLLAMA_BASE_URL=
# Optional for Ollama Cloud
OLLAMA_API_KEY=

# Pexels - For AI B-Roll (free stock video footage)
# Get your free API key at: https://www.pexels.com/api/
PEXELS_API_KEY=

# Optional paid fallback for YouTube downloads
APIFY_API_TOKEN=

# YouTube download provider
# `yt_dlp` is the free default and works without APIFY_API_TOKEN.
# `apify` uses the Apify actor first, then falls back to yt-dlp.
YOUTUBE_DOWNLOAD_PROVIDER=yt_dlp

# YouTube metadata provider
# `yt_dlp` keeps the current behavior.
# `youtube_data_api` uses the official YouTube Data API first, then falls back to yt-dlp.
YOUTUBE_METADATA_PROVIDER=yt_dlp

# Preferred key for the YouTube Data API metadata path.
# If omitted, metadata requests fall back to GOOGLE_API_KEY when available.
YOUTUBE_DATA_API_KEY=

# ==============================================
# AI Model Configuration
# ==============================================

# Format: "provider:model-name"
# IMPORTANT: Hosted providers require the matching API key above.
# Ollama can run locally without an API key.
# Examples:
#   - openai:gpt-5.2 (requires OPENAI_API_KEY) - latest, best reasoning
#   - google-gla:gemini-3-flash-preview (requires GOOGLE_API_KEY) - fast, cost-effective
#   - anthropic:claude-4-sonnet (requires ANTHROPIC_API_KEY)
#   - ollama:gpt-oss:20b (uses local Ollama by default, optional OLLAMA_BASE_URL)
LLM=google-gla:gemini-3-flash-preview
# Optional comma-separated fallback LLMs tried if the primary provider/model is overloaded or unavailable.
# Only include providers whose API keys are set above.
LLM_FALLBACKS=openai:gpt-5.2,anthropic:claude-4-sonnet

# Whisper model size (tiny, base, small, medium, large)
# Larger models are more accurate but slower
WHISPER_MODEL_SIZE=medium

# Mark stale queued tasks as error after this many seconds
QUEUED_TASK_TIMEOUT_SECONDS=180

# Default target resolution requested from the Apify YouTube downloader when enabled
APIFY_YOUTUBE_DEFAULT_QUALITY=1080

# Processing defaults
DEFAULT_PROCESSING_MODE=fast
FAST_MODE_MAX_CLIPS=4
FAST_MODE_TRANSCRIPT_MODEL=nano

# ==============================================
# Authentication
# ==============================================

# Better Auth secret (change this in production!)
# Generate a secure random string for production
BETTER_AUTH_SECRET=supoclip_dev_secret_change_in_production

# Set to true/1/yes to disable new user sign-ups.
DISABLE_SIGN_UP=false

# Set to true to disable all routes except the landing page.
NEXT_PUBLIC_LANDING_ONLY_MODE=false

# ==============================================
# Analytics (optional)
# ==============================================

# DataFast public website ID (example: dfid_xxxxxx)
NEXT_PUBLIC_DATAFAST_WEBSITE_ID=

# DataFast tracked domain without protocol (example: your-domain.com)
NEXT_PUBLIC_DATAFAST_DOMAIN=

# Set to true only when you want to test DataFast on localhost
NEXT_PUBLIC_DATAFAST_ALLOW_LOCALHOST=false

# Resend API key for waitlist confirmation emails (optional)
RESEND_API_KEY=
RESEND_FROM_EMAIL="THIH Clip Engine <onboarding@your-domain.com>"
# Frontend/backend URLs
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3107
# Used by frontend server routes inside Docker. Keep this as-is for Docker Compose.
BACKEND_INTERNAL_URL=http://backend:8000

# ==============================================
# Monetization (optional, disabled by default)
# ==============================================

# Open-source/self-host mode. Monetization is only enabled when SELF_HOST=false
SELF_HOST=true
BACKEND_AUTH_SECRET=change_me_backend_auth_secret
APP_SETTINGS_ENCRYPTION_KEY=change_me_settings_encryption_secret
ALLOW_UNSIGNED_BACKEND_AUTH=false
AUTH_SIGNATURE_TTL_SECONDS=300
# Include the frontend origin because browser video uploads go directly to the backend.
CORS_ORIGINS=http://localhost:3107,http://sp.localhost:3107,http://supoclip.localhost:3107

# Hosted mode does not allow free processing. This is reserved for future use.
FREE_PLAN_TASK_LIMIT=10

# Paid plan monthly generation limits
PRO_PLAN_TASK_LIMIT=50
SCALE_PLAN_TASK_LIMIT=300

# Stripe settings (required only when SELF_HOST=false)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Legacy fallback for the Pro price ID. Prefer STRIPE_PRO_PRICE_ID for new setups.
STRIPE_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_SCALE_PRICE_ID=
NEXT_PUBLIC_PRO_PRICE_MONTHLY=10
NEXT_PUBLIC_SCALE_PRICE_MONTHLY=50
NEXT_PUBLIC_FREE_PLAN_TASK_LIMIT=10
NEXT_PUBLIC_PRO_PLAN_TASK_LIMIT=50
NEXT_PUBLIC_SCALE_PLAN_TASK_LIMIT=300

# Optional fallback links when Stripe sessions are not configured
STRIPE_CHECKOUT_URL=
STRIPE_CUSTOMER_PORTAL_URL=

# ==============================================
# Feedback (optional — posts to Discord)
# ==============================================

# Discord webhook URLs (each posts to a separate channel)
DISCORD_FEEDBACK_WEBHOOK_URL=
DISCORD_SALES_WEBHOOK_URL=

# ==============================================
# Database Configuration
# ==============================================

# PostgreSQL credentials (matches docker-compose.yml)
POSTGRES_DB=supoclip
POSTGRES_USER=supoclip
POSTGRES_PASSWORD=supoclip_password
# Local backend command uses DATABASE_URL directly. Docker Compose injects its own service URL.
DATABASE_URL=postgresql+asyncpg://supoclip:supoclip_password@localhost:5432/supoclip

# Redis settings for Docker/local development.
REDIS_HOST=localhost
REDIS_PORT=6379
# Leave blank to run Redis without AUTH, or set a value to require authentication.
REDIS_PASSWORD=

# ==============================================
# Docker Performance
# ==============================================

# Enable BuildKit for faster Docker builds
COMPOSE_DOCKER_CLI_BUILD=1
DOCKER_BUILDKIT=1

